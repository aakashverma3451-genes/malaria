# ─── Postgres ────────────────────────────────────────────────────────────────
DB_NAME=malaria_genomics
DB_USER=malaria
DB_PASSWORD=BGIBEIJING
DB_HOST=postgres
DB_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=BGIBEIJING
MINIO_BUCKET=genomics-data
MINIO_SECURE=false

# ─── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=BGIBEIJING
KEYCLOAK_REALM=malaria
KEYCLOAK_CLIENT_ID=malaria-api
KEYCLOAK_WEB_CLIENT_ID=malaria-web
KEYCLOAK_CLIENT_SECRET=BGIBEIJING

# ─── FastAPI Backend ──────────────────1───────────────────────────────────────
SECRET_KEY=BGIBEIJING
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Next.js Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret
KEYCLOAK_ISSUER=http://localhost:8080/realms/malaria

# ─── Celery / Flower ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1
FLOWER_USER=admin
FLOWER_PASSWORD=BGIBEIJING

# ─── Pipeline Staging ────────────────────────────────────────────────────────
PIPELINE_STAGING_DIR=/staging
